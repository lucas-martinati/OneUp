{
  "name": "OneUp",
  "private": true,
  "version": "3.3.0",
  "type": "module",
  "scripts": {
    "postinstall": "patch-package",
    "generate:config": "node scripts/generate-config.js",
    "predev": "npm run generate:config",
    "dev": "vite",
    "prebuild": "npm run generate:config",
    "build": "vite build",
    "build:bundle": "NATIVE_BUILD=true npm run build && npx cap copy android && cd android && ./gradlew bundleRelease",
    "build:apk": "NATIVE_BUILD=true npm run build && npx cap copy android && cd android && ./gradlew assembleProdRelease",
    "build:apk:dev": "NATIVE_BUILD=true npm run build && npx cap copy android && cd android && ./gradlew assembleDevRelease",
    "deploy:android": "NATIVE_BUILD=true npm run build && npx cap sync android && npx cap run android --flavor dev",
    "deploy:android:prod": "NATIVE_BUILD=true npm run build && npx cap sync android && npx cap run android --flavor prod",
    "lint": "node scripts/run-all-lints.cjs",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:circular": "madge --circular src",
    "lint:dup": "jscpd",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && playwright test",
    "preview": "vite preview",
    "deploy": "npm run build && firebase deploy --only hosting --project oneup-1c3f5",
    "deploy:github-pages": "GITHUB_PAGES=true npm run build && gh-pages -d dist -b gh-pages --dotfiles",
    "deploy:functions": "firebase deploy --only functions --project oneup-1c3f5",
    "deploy:database": "firebase deploy --only database --project oneup-1c3f5",
    "secrets:set": "bash scripts/set-secrets.sh",
    "db:audit": "node scripts/firebase-helper.js audit",
    "db:prune": "node scripts/firebase-helper.js prune"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/local-notifications": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/share": "^8.0.1",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
    "@react-oauth/google": "^0.13.4",
    "@revenuecat/purchases-capacitor": "^12.3.0",
    "@revenuecat/purchases-js": "^1.13.2",
    "capacitor-health": "^8.1.2",
    "firebase": "^12.7.0",
    "html-to-image": "^1.11.13",
    "i18next": "^25.10.5",
    "i18next-browser-languagedetector": "^8.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-easy-crop": "^5.5.7",
    "react-i18next": "^16.6.2",
    "react-leaflet": "^5.0.0",
    "zustand": "^5.0.13"
  },
  "overrides": {
    "@codetrix-studio/capacitor-google-auth": {
      "@capacitor/core": "$@capacitor/core"
    }
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-sonarjs": "^4.1.0",
    "firebase-tools": "^15.22.3",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "jscpd": "^5.0.10",
    "jsdom": "^29.0.1",
    "knip": "^6.9.0",
    "madge": "^8.0.0",
    "patch-package": "^8.0.1",
    "playwright": "^1.59.1",
    "stylelint": "^17.13.0",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2"
  },
  "jscpd": {
    "path": [
      "src"
    ],
    "format": [
      "javascript",
      "jsx"
    ],
    "minLines": 10,
    "minTokens": 70,
    "threshold": 2,
    "ignore": [
      "**/__tests__/**",
      "**/*.test.{js,jsx}",
      "**/*.spec.{js,jsx}"
    ],
    "reporters": [
      "console"
    ],
    "gitignore": true
  },
  "madge": {
    "fileExtensions": [
      "js",
      "jsx"
    ],
    "webpackConfig": "scripts/madge-resolve.config.cjs",
    "detectiveOptions": {
      "es6": {
        "skipTypeImports": true
      }
    }
  }
}
