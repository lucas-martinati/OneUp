{
  "name": "pushup-tracker",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "generate:config": "node scripts/generate-config.js",
    "predev": "npm run generate:config",
    "dev": "vite",
    "prebuild": "npm run generate:config",
    "build": "vite build",
    "build:bundle": "npm run build && npx cap copy android && cd android && ./gradlew bundleRelease",
    "build:apk": "npm run build && npx cap copy android && cd android && ./gradlew assembleRelease",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "deploy:functions": "npx firebase-tools deploy --only functions --project oneup-1c3f5",
    "deploy": "GITHUB_PAGES=true npm run build && gh-pages -d dist -b gh-pages --dotfiles"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/local-notifications": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
    "@react-oauth/google": "^0.13.4",
    "@revenuecat/purchases-capacitor": "^12.3.0",
    "@revenuecat/purchases-js": "^1.13.2",
    "firebase": "^12.7.0",
    "i18next": "^25.10.5",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.6.2",
    "react-is": "^19.2.3",
    "recharts": "^3.6.0"
  },
  "overrides": {
    "@codetrix-studio/capacitor-google-auth": {
      "@capacitor/core": "$@capacitor/core"
    }
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@eslint/js": "^9.39.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "i18next-parser": "^9.4.0",
    "jsdom": "^29.0.1",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2"
  }
}
