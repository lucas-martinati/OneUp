<?xml version="1.0" encoding="utf-8"?>
<!-- Frozen day — streak freeze used, icy frosted-glass look with snowflake accent -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer glow (icy blue instead of violet) -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#3038bdf8" />
            <size android:width="28dp" android:height="28dp" />
        </shape>
    </item>

    <!-- Inner gradient circle — frosted glass -->
    <item android:bottom="2dp" android:left="2dp" android:right="2dp" android:top="2dp">
        <shape android:shape="oval">
            <gradient
                android:startColor="#FFE0F2FE"
                android:endColor="#FF38BDF8"
                android:angle="135" />
            <size android:width="24dp" android:height="24dp" />
        </shape>
    </item>

    <!-- Frost rim -->
    <item android:bottom="2dp" android:left="2dp" android:right="2dp" android:top="2dp">
        <shape android:shape="oval">
            <stroke
                android:width="1dp"
                android:color="#80FFFFFF" />
            <size android:width="24dp" android:height="24dp" />
        </shape>
    </item>

    <!-- Shine highlight (identique à l'originale) -->
    <item android:bottom="6dp" android:left="5dp" android:right="5dp" android:top="3dp">
        <shape android:shape="oval">
            <gradient
                android:startColor="#50FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
            <size android:width="14dp" android:height="14dp" />
        </shape>
    </item>

    <!-- Accent flocon : 3 barres à 0°/60°/120° -->
    <item android:bottom="8dp" android:left="8dp" android:right="8dp" android:top="8dp">
        <rotate
            android:fromDegrees="0"
            android:toDegrees="0"
            android:pivotX="50%"
            android:pivotY="50%">
            <shape android:shape="rectangle">
                <solid android:color="#E6FFFFFF" />
                <corners android:radius="1dp" />
                <size android:width="1.6dp" android:height="12dp" />
            </shape>
        </rotate>
    </item>
    <item android:bottom="8dp" android:left="8dp" android:right="8dp" android:top="8dp">
        <rotate
            android:fromDegrees="60"
            android:toDegrees="60"
            android:pivotX="50%"
            android:pivotY="50%">
            <shape android:shape="rectangle">
                <solid android:color="#E6FFFFFF" />
                <corners android:radius="1dp" />
                <size android:width="1.6dp" android:height="12dp" />
            </shape>
        </rotate>
    </item>
    <item android:bottom="8dp" android:left="8dp" android:right="8dp" android:top="8dp">
        <rotate
            android:fromDegrees="120"
            android:toDegrees="120"
            android:pivotX="50%"
            android:pivotY="50%">
            <shape android:shape="rectangle">
                <solid android:color="#E6FFFFFF" />
                <corners android:radius="1dp" />
                <size android:width="1.6dp" android:height="12dp" />
            </shape>
        </rotate>
    </item>

</layer-list>