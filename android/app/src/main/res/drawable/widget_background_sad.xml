<?xml version="1.0" encoding="utf-8"?>
<!-- Frozen/icy widget background when streak is 0 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Cold blue base -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:startColor="#0a1628"
                android:centerColor="#0f1e35"
                android:endColor="#0b1525"
                android:angle="135" />
        </shape>
    </item>
    <!-- Icy frost overlay -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:startColor="#18a0c8ff"
                android:endColor="#00000000"
                android:angle="180" />
        </shape>
    </item>
    <!-- Icy border -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="#205b9bd5" />
            <solid android:color="#00000000" />
        </shape>
    </item>
</layer-list>
