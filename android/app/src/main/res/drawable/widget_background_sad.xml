<?xml version="1.0" encoding="utf-8"?>
<!-- Dimmed/dormant widget background when streak is 0 — desaturated, cool, low energy -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Cold dark base -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:startColor="#FF090b11"
                android:centerColor="#FF0a0d14"
                android:endColor="#FF080a0f"
                android:angle="135" />
        </shape>
    </item>

    <!-- Faint icy sheen from the top -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:startColor="#120ea5e9"
                android:endColor="#00000000"
                android:angle="270" />
        </shape>
    </item>

    <!-- Dim cool border -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <stroke android:width="1dp" android:color="#1a38bdf8" />
            <solid android:color="#00000000" />
        </shape>
    </item>

</layer-list>
