<?xml version="1.0" encoding="utf-8"?>
<!-- Current day — glowing cyan ring (present but not yet completed) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer cyan glow -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#3522d3ee" />
            <size android:width="28dp" android:height="28dp" />
        </shape>
    </item>
    <!-- Faint inner fill so the ring reads as "active now" -->
    <item android:bottom="2dp" android:left="2dp" android:right="2dp" android:top="2dp">
        <shape android:shape="oval">
            <solid android:color="#2222d3ee" />
            <size android:width="24dp" android:height="24dp" />
        </shape>
    </item>
    <!-- Bright cyan ring -->
    <item android:bottom="2dp" android:left="2dp" android:right="2dp" android:top="2dp">
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="#FF22d3ee" />
            <solid android:color="#00000000" />
            <size android:width="24dp" android:height="24dp" />
        </shape>
    </item>
</layer-list>
