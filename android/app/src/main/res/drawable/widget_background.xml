<?xml version="1.0" encoding="utf-8"?>
<!-- OneUp widget background — near-black with a subtle purple→cyan brand wash -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Deep base (matches app bg #050505 / splash #0A0A0A) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:startColor="#FF0a0a12"
                android:centerColor="#FF0b0a14"
                android:endColor="#FF08080e"
                android:angle="135" />
        </shape>
    </item>

    <!-- Brand wash: faint violet→cyan diagonal tint -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:startColor="#1a8b5cf6"
                android:centerColor="#0c6d28d9"
                android:endColor="#160ea5e9"
                android:angle="135" />
        </shape>
    </item>

    <!-- Soft top highlight for depth -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:startColor="#14FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
        </shape>
    </item>

    <!-- Hairline border -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <stroke android:width="1dp" android:color="#26FFFFFF" />
            <solid android:color="#00000000" />
        </shape>
    </item>

</layer-list>
