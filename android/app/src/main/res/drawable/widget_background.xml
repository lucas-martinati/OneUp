<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer shadow/glow -->
    <item android:bottom="1dp" android:left="1dp" android:right="1dp" android:top="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#40000000" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <!-- Main gradient background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FF0f0f23"
                android:centerColor="#FF1a1a3e"
                android:endColor="#FF12122b"
                android:angle="135" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <!-- Subtle top highlight -->
    <item android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#18FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <!-- Border -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#20FFFFFF" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>
