<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_large_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="14dp"
    android:paddingBottom="14dp"
    android:clipToPadding="false">

    <!-- Top row: flame + streak count + label -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <!-- Flame icon -->
        <ImageView
            android:id="@+id/widget_large_flame_icon"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_flame"
            android:contentDescription="Streak"
            android:scaleType="fitCenter" />

        <!-- Streak number -->
        <TextView
            android:id="@+id/widget_large_streak_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFFFF"
            android:textSize="34sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="10dp"
            android:includeFontPadding="false" />

        <!-- "jours" label -->
        <TextView
            android:id="@+id/widget_large_streak_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DAYS"
            android:textColor="#60FFFFFF"
            android:textSize="12sp"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginStart="8dp"
            android:includeFontPadding="false" />
    </LinearLayout>

    <!-- Divider line (ImageView because RemoteViews doesn't support View before API 31) -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:src="@drawable/widget_divider"
        android:scaleType="fitXY"
        android:layout_marginBottom="14dp"
        android:contentDescription="" />

    <!-- Week days labels -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp">

        <TextView android:id="@+id/label_mon" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="M" android:textColor="#60FFFFFF" android:textSize="11sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" android:letterSpacing="0.05" />
        <TextView android:id="@+id/label_tue" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="T" android:textColor="#60FFFFFF" android:textSize="11sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" android:letterSpacing="0.05" />
        <TextView android:id="@+id/label_wed" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="W" android:textColor="#60FFFFFF" android:textSize="11sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" android:letterSpacing="0.05" />
        <TextView android:id="@+id/label_thu" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="T" android:textColor="#60FFFFFF" android:textSize="11sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" android:letterSpacing="0.05" />
        <TextView android:id="@+id/label_fri" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="F" android:textColor="#60FFFFFF" android:textSize="11sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" android:letterSpacing="0.05" />
        <TextView android:id="@+id/label_sat" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="S" android:textColor="#60FFFFFF" android:textSize="11sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" android:letterSpacing="0.05" />
        <TextView android:id="@+id/label_sun" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="S" android:textColor="#60FFFFFF" android:textSize="11sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" android:letterSpacing="0.05" />
    </LinearLayout>

    <!-- Week days dots -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
            <ImageView android:id="@+id/dot_mon" android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@drawable/dot_pending" android:contentDescription="Monday" />
        </FrameLayout>
        <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
            <ImageView android:id="@+id/dot_tue" android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@drawable/dot_pending" android:contentDescription="Tuesday" />
        </FrameLayout>
        <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
            <ImageView android:id="@+id/dot_wed" android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@drawable/dot_pending" android:contentDescription="Wednesday" />
        </FrameLayout>
        <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
            <ImageView android:id="@+id/dot_thu" android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@drawable/dot_pending" android:contentDescription="Thursday" />
        </FrameLayout>
        <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
            <ImageView android:id="@+id/dot_fri" android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@drawable/dot_pending" android:contentDescription="Friday" />
        </FrameLayout>
        <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
            <ImageView android:id="@+id/dot_sat" android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@drawable/dot_pending" android:contentDescription="Saturday" />
        </FrameLayout>
        <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
            <ImageView android:id="@+id/dot_sun" android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@drawable/dot_pending" android:contentDescription="Sunday" />
        </FrameLayout>
    </LinearLayout>

</LinearLayout>
