{
  "rules": {
    ".read": "auth != null && auth.uid === 'bAI8hvjR5TdIu0hDEDh4uP2MyCh1'",
    ".write": "auth != null && auth.uid === 'bAI8hvjR5TdIu0hDEDh4uP2MyCh1'",
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        "progress": {
          // Intentionnel : la lecture est ouverte à tout utilisateur authentifié
          // pour permettre les fonctionnalités sociales (clans, classement, profils).
          ".read": "auth != null",
          ".write": "$uid === auth.uid"
        },
        "$topic": {
          ".write": "$uid === auth.uid && $topic !== 'purchase'"
        }
      }
    },
    "leaderboard": {
      ".read": "auth != null",
      "$uid": {
        ".write": false
      }
    },
    "clans": {
      ".read": "auth != null",
      "$clanId": {
        ".write": "auth != null && (!data.exists() || (!newData.exists() && !data.child('members').exists()))",
        "members": {
          "$memberUid": {
            ".write": "auth != null && $memberUid === auth.uid"
          }
        }
      }
    },
    "notifications": {
      "$uid": {
        ".read": "auth != null && $uid === auth.uid",
        "$notifId": {
          ".write": "auth != null && (!data.exists() && newData.child('fromUid').val() === auth.uid || $uid === auth.uid)"
        }
      }
    }
  }
}
