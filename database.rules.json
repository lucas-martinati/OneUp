{
  "rules": {
    ".read": "auth != null && auth.uid === 'bAI8hvjR5TdIu0hDEDh4uP2MyCh1'",
    ".write": "auth != null && auth.uid === 'bAI8hvjR5TdIu0hDEDh4uP2MyCh1'",
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        "progress": {
          // TRANSITOIRE : lecture ouverte à tout utilisateur authentifié, héritée
          // de l'ancien modèle social. Les nouveaux clients lisent désormais les
          // stats publiques dérivées dans `publicProfiles` (sans le calendrier ni
          // les traces GPS privées). À FERMER en `$uid === auth.uid` une fois que
          // l'adoption de la version migrée est suffisante (ferme la fuite GPS).
          ".read": "auth != null",
          ".write": "$uid === auth.uid"
        },
        "$topic": {
          ".write": "$uid === auth.uid && $topic !== 'purchase'"
        }
      }
    },
    "leaderboard": {
      ".read": "auth != null",
      "$uid": {
        ".write": false
      }
    },
    "publicProfiles": {
      // Stats publiques dérivées (par exercice + streaks), calculées et écrites
      // EXCLUSIVEMENT par la Cloud Function recomputeLeaderboardEntry. Lecture
      // pour tout utilisateur authentifié, écriture client interdite. Permet la
      // fiche détail sociale sans lire le `progress` privé d'autrui.
      ".read": "auth != null",
      "$uid": {
        ".write": false
      }
    },
    "clans": {
      ".read": "auth != null",
      ".indexOn": ["code"],
      "$clanId": {
        ".write": "auth != null && ((!data.exists() && newData.child('createdBy').val() === auth.uid) || (!newData.exists() && !data.child('members').exists()))",
        "members": {
          "$memberUid": {
            ".write": "auth != null && $memberUid === auth.uid"
          }
        }
      }
    },
    "clanCodes": {
      ".read": "auth != null",
      "$code": {
        ".write": "auth != null && ((!data.exists() && newData.exists()) || (!newData.exists() && (!root.child('clans').child(data.val()).exists() || !root.child('clans').child(data.val()).child('members').exists() || root.child('clans').child(data.val()).child('members').child(auth.uid).exists())))"
      }
    },
    "notifications": {
      "$uid": {
        ".read": "auth != null && $uid === auth.uid",
        "$senderUid": {
          // Pokes are aggregated per sender: the node is keyed by the sender's
          // uid. A sender may create OR update (increment) only their own node
          // and must stamp fromUid as themselves; the recipient may do anything
          // to their own notifications (e.g. delete on dismiss).
          // The sender also needs read on their own node so the increment
          // transaction can see the current count.
          ".read": "auth != null && ($senderUid === auth.uid || $uid === auth.uid)",
          ".write": "auth != null && (($senderUid === auth.uid && (!newData.exists() || newData.child('fromUid').val() === auth.uid)) || $uid === auth.uid)"
        }
      }
    }
  }
}
